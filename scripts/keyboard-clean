#!/usr/bin/env bash
set -euo pipefail

SECONDS_TO_LOCK="${1:-45}"
ALLOW_ESCAPE="${ALLOW_ESCAPE:-true}"

case "$(uname -s)" in
  Darwin)
    BIN_PATH="./.build/debug/keyboard-clean"

    if [[ ! -x "$BIN_PATH" ]]; then
      swift build
    fi

    "$BIN_PATH" --seconds "$SECONDS_TO_LOCK" --allow-escape "$ALLOW_ESCAPE"
    ;;
  Linux)
    "$(dirname "$0")/keyboard-clean-linux" "$SECONDS_TO_LOCK"
    ;;
  CYGWIN*|MINGW*|MSYS*)
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$(dirname "$0")/keyboard-clean-windows.ps1" -Seconds "$SECONDS_TO_LOCK"
    ;;
  *)
    echo "Unsupported OS: $(uname -s)" >&2
    exit 1
    ;;
esac
